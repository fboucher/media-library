@using MediaLibrary.Data
@using MediaLibrary.Models
@using MediaLibrary.Services
@inject MediaRepository MediaRepo
@inject AiService AiService
@inject AppState AppState
@inject ISnackbar Snackbar
@inject IConfiguration Config
@inject DetectionRepository DetectionRepo
@inject IJSRuntime JS

@if (Item is not null)
{
    <div>

        <div style="position:relative;width:100%;max-height:240px;margin-bottom:16px;background:var(--mud-palette-background-grey);border-radius:4px;overflow:hidden;cursor:pointer"
             @onclick="OpenLightbox">
            <img @ref="_imgRef"
                 src="@Item.ThumbnailUrl"
                 alt="@Item.FileName"
                 style="width:100%;max-height:240px;object-fit:contain;display:block;border-radius:4px" />
            <svg style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none">
                @((MarkupString)BuildSvgContent())
            </svg>
        </div>

        @if (_lightboxOpen)
        {
            <div style="position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:9000;background:rgba(0,0,0,0.92);display:flex;align-items:center;justify-content:center"
                 @onclick="CloseLightbox">
                <div style="position:relative;width:100%;height:100%;display:flex;align-items:center;justify-content:center"
                     @onclick:stopPropagation>
                    <img @ref="_lightboxImgRef"
                         src="@Item.ThumbnailUrl"
                         alt="@Item.FileName"
                         @onload="OnLightboxImageLoaded"
                         style="max-width:100%;max-height:100%;object-fit:contain;display:block" />
                    <svg style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none">
                        @((MarkupString)BuildLightboxSvgContent())
                    </svg>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Style="position:absolute;top:16px;right:16px;color:white"
                               OnClick="CloseLightbox" />
            </div>
        }

        <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-1">File name</MudText>
        <MudText Typo="Typo.body1" Class="mb-3" Style="word-break:break-all">@Item.FileName</MudText>

        <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-1">File size</MudText>
        <MudText Typo="Typo.body1" Class="mb-3">@Item.FileSizeDisplay</MudText>

        <MudTextField @bind-Value="_description"
                      Label="Description"
                      Lines="5"
                      Variant="Variant.Outlined"
                      Class="mb-3" />

        @if (_aiError is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-2" Dense="true">@_aiError</MudAlert>
        }

        <MudStack Row="true" Spacing="2" Class="mb-2">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SaveAsync">
                Save
            </MudButton>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       OnClick="FillWithAiAsync"
                       Disabled="@(AppState.ActiveConnection is null || _aiLoading)">
                @(_aiLoading ? "Analyzing…" : "Fill with AI")
            </MudButton>
        </MudStack>

        @if (!Item!.IsVideo)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
                <MudTextField @bind-Value="_detectWord"
                              Placeholder="Detect objects…"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Style="flex:1" />
                <MudButton Variant="Variant.Outlined"
                           OnClick="DetectAsync"
                           Disabled="@(AppState.ActiveConnection is null || _detecting || string.IsNullOrWhiteSpace(_detectWord))">
                    @(_detecting ? "Detecting…" : "Detect")
                </MudButton>
            </MudStack>

            @if (_detectError is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mb-2" Dense="true">@_detectError</MudAlert>
            }

            @if (_detectRawText is not null)
            {
                <MudAlert Severity="Severity.Info" Class="mb-2" Dense="true"
                          ShowCloseIcon="true" CloseIconClicked="() => _detectRawText = null">@StripMarkdown(_detectRawText)</MudAlert>
            }
        }

        @if (_confirmingDelete)
        {
            <MudAlert Severity="Severity.Warning" Class="mt-2">
                <MudText>Delete "@Item?.FileName"? This cannot be undone.</MudText>
                <MudStack Row="true" Spacing="1" Class="mt-2">
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteAsync">Yes, delete</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="() => _confirmingDelete = false">Cancel</MudButton>
                </MudStack>
            </MudAlert>
        }
        else
        {
            <MudButton Variant="Variant.Text"
                       Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="() => _confirmingDelete = true">
                Delete
            </MudButton>
        }

        @if (_detections.Count > 0)
        {
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mt-3 mb-1">Detection history</MudText>
            <div style="max-height:128px;overflow-y:auto;border:1px solid var(--mud-palette-divider);border-radius:4px">
                @foreach (var d in _detections)
                {
                    <div style="padding:6px 10px;cursor:pointer;@(_activeDetection?.Id == d.Id ? "background:var(--mud-palette-action-default-hover)" : "")"
                         title="@d.CreatedAt.ToLocalTime().ToString("g")"
                         @onclick="async () => await SelectDetection(d)">
                        <MudText Typo="Typo.body2">@d.ResearchWord</MudText>
                    </div>
                }
            </div>
        }

    </div>
}

@code {
    [Parameter, EditorRequired] public MediaItem? Item { get; set; }
    [Parameter] public EventCallback<MediaItem> OnSaved { get; set; }
    [Parameter] public EventCallback<MediaItem> OnDeleted { get; set; }

    private string _description = "";
    private bool _confirmingDelete;
    private bool _aiLoading;
    private string? _aiError;

    private List<Detection> _detections = [];
    private Detection? _activeDetection;
    private string _detectWord = "";
    private bool _detecting;
    private string? _detectError;
    private string? _detectRawText;

    private ElementReference _imgRef;
    private List<SvgBox> _svgBoxes = [];

    private bool _lightboxOpen;
    private ElementReference _lightboxImgRef;
    private List<SvgBox> _lightboxSvgBoxes = [];
    private List<DetectedObject> _currentObjects = [];

    private record SvgBox(double X, double Y, double W, double H, string Label);

    private string BuildSvgContent()
    {
        var sb = new System.Text.StringBuilder();
        foreach (var box in _svgBoxes)
        {
            var label = System.Net.WebUtility.HtmlEncode(box.Label);
            sb.Append($"<rect x='{box.X:F1}' y='{box.Y:F1}' width='{box.W:F1}' height='{box.H:F1}' fill='none' stroke='red' stroke-width='2'/>");
            sb.Append($"<text x='{(box.X + 2):F1}' y='{(box.Y + 14):F1}' fill='red' font-size='11' font-family='sans-serif' style='text-shadow:0 0 3px #000'>{label}</text>");
        }
        return sb.ToString();
    }

    protected override async Task OnParametersSetAsync()
    {
        _description      = Item?.Description ?? "";
        _confirmingDelete = false;
        _aiError          = null;
        _activeDetection  = null;
        _detectWord       = "";
        _detectError      = null;
        _detectRawText    = null;
        _svgBoxes         = [];
        _lightboxOpen     = false;
        _lightboxSvgBoxes = [];
        _currentObjects   = [];

        if (Item is not null)
            _detections = (await DetectionRepo.GetByMediaIdAsync(Item.Id)).ToList();
        else
            _detections = [];
    }

    private async Task SelectDetection(Detection d)
    {
        _activeDetection = d;
        await DrawDetectionAsync(d);
    }

    private async Task DrawDetectionAsync(Detection d)
    {
        var objects = System.Text.Json.JsonSerializer.Deserialize<List<DetectedObject>>(d.DetectedJson) ?? [];
        await DrawObjectsAsync(objects);
    }

    private async Task DrawObjectsAsync(List<DetectedObject> objects)
    {
        _currentObjects = objects;
        _svgBoxes = [];

        var bounds = await JS.InvokeAsync<ImageBounds?>("getImageRenderBounds", _imgRef);
        if (bounds is null || bounds.Width == 0 || bounds.Height == 0) return;

        foreach (var obj in objects)
        {
            foreach (var bboxStr in obj.Bboxes)
            {
                var parts = bboxStr.Split(',');
                if (parts.Length != 4) continue;
                if (!double.TryParse(parts[0], out var x1) || !double.TryParse(parts[1], out var y1) ||
                    !double.TryParse(parts[2], out var x2) || !double.TryParse(parts[3], out var y2))
                    continue;

                var px = bounds.Left + x1 / 100.0 * bounds.Width;
                var py = bounds.Top  + y1 / 100.0 * bounds.Height;
                var pw = (x2 - x1) / 100.0 * bounds.Width;
                var ph = (y2 - y1) / 100.0 * bounds.Height;

                _svgBoxes.Add(new SvgBox(px, py, pw, ph, obj.Ref));
            }
        }
    }

    private void OpenLightbox()
    {
        _lightboxOpen     = true;
        _lightboxSvgBoxes = [];
    }

    private void CloseLightbox() => _lightboxOpen = false;

    private async Task OnLightboxImageLoaded()
    {
        _lightboxSvgBoxes = [];
        if (_currentObjects.Count == 0) return;

        var bounds = await JS.InvokeAsync<ImageBounds?>("getImageRenderBounds", _lightboxImgRef);
        if (bounds is null || bounds.Width == 0 || bounds.Height == 0) return;

        foreach (var obj in _currentObjects)
        {
            foreach (var bboxStr in obj.Bboxes)
            {
                var parts = bboxStr.Split(',');
                if (parts.Length != 4) continue;
                if (!double.TryParse(parts[0], out var x1) || !double.TryParse(parts[1], out var y1) ||
                    !double.TryParse(parts[2], out var x2) || !double.TryParse(parts[3], out var y2))
                    continue;

                var px = bounds.Left + x1 / 100.0 * bounds.Width;
                var py = bounds.Top  + y1 / 100.0 * bounds.Height;
                var pw = (x2 - x1) / 100.0 * bounds.Width;
                var ph = (y2 - y1) / 100.0 * bounds.Height;

                _lightboxSvgBoxes.Add(new SvgBox(px, py, pw, ph, obj.Ref));
            }
        }
    }

    private string BuildLightboxSvgContent()
    {
        var sb = new System.Text.StringBuilder();
        foreach (var box in _lightboxSvgBoxes)
        {
            var label = System.Net.WebUtility.HtmlEncode(box.Label);
            sb.Append($"<rect x='{box.X:F1}' y='{box.Y:F1}' width='{box.W:F1}' height='{box.H:F1}' fill='none' stroke='red' stroke-width='3'/>");
            sb.Append($"<text x='{(box.X + 3):F1}' y='{(box.Y + 18):F1}' fill='red' font-size='14' font-family='sans-serif' style='text-shadow:0 0 4px #000'>{label}</text>");
        }
        return sb.ToString();
    }

    private static string StripMarkdown(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return "";
        var s = System.Text.RegularExpressions.Regex.Replace(text, @"\*{1,3}(.*?)\*{1,3}", "$1");
        s = System.Text.RegularExpressions.Regex.Replace(s, @"_{1,2}(.*?)_{1,2}", "$1");
        s = System.Text.RegularExpressions.Regex.Replace(s, @"^[\*\-\+]\s+", "", System.Text.RegularExpressions.RegexOptions.Multiline);
        s = System.Text.RegularExpressions.Regex.Replace(s, @"^\s*#+\s+", "", System.Text.RegularExpressions.RegexOptions.Multiline);
        return s.Trim();
    }

    private class ImageBounds
    {
        public double Left   { get; set; }
        public double Top    { get; set; }
        public double Width  { get; set; }
        public double Height { get; set; }
    }

    private async Task DetectAsync()
    {
        if (Item is null || AppState.ActiveConnection is null) return;

        _detecting      = true;
        _detectError    = null;
        _detectRawText  = null;

        try
        {
            var (objects, rawText) = await AiService.DetectAsync(AppState.ActiveConnection, _detectWord, Item);

            if (objects.Count == 0)
            {
                Snackbar.Add("Nothing detected.", Severity.Info);
                if (!string.IsNullOrWhiteSpace(rawText))
                    _detectRawText = rawText;
                return;
            }

            var detection = new Detection
            {
                MediaId      = Item.Id,
                ResearchWord = _detectWord,
                DetectedJson = System.Text.Json.JsonSerializer.Serialize(objects),
                CreatedAt    = DateTime.UtcNow
            };
            detection.Id = await DetectionRepo.InsertAsync(detection);
            _detections.Insert(0, detection);
            _activeDetection = detection;
            await DrawObjectsAsync(objects);
        }
        catch (Exception ex)
        {
            _detectError = ex.Message;
        }
        finally
        {
            _detecting = false;
        }
    }

    private async Task SaveAsync()
    {
        if (Item is null) return;
        await MediaRepo.UpdateDescriptionAsync(Item.Id, _description);
        Item.Description = _description;
        Snackbar.Add("Saved.", Severity.Success);
        await OnSaved.InvokeAsync(Item);
    }

    private async Task FillWithAiAsync()
    {
        if (Item is null || AppState.ActiveConnection is null) return;

        _aiLoading = true;
        _aiError   = null;

        try
        {
            _description = await AiService.AnalyzeAsync(
                AppState.ActiveConnection, AppState.Prompt, Item);
        }
        catch (Exception ex)
        {
            _aiError = ex.Message;
        }
        finally
        {
            _aiLoading = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (Item is null) return;

        var mediaRoot = Config["Media:StoragePath"] ?? "/data/media";

        var filePath = Path.Combine(mediaRoot, Item.FileName);
        if (File.Exists(filePath))
            File.Delete(filePath);

        if (Item.ThumbnailPath is not null && File.Exists(Item.ThumbnailPath))
            File.Delete(Item.ThumbnailPath);

        await MediaRepo.DeleteAsync(Item.Id);
        Snackbar.Add("Deleted.", Severity.Info);
        await OnDeleted.InvokeAsync(Item);
    }
}
